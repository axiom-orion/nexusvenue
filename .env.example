# Neo4j (docker-compose defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexusvenue

# Anthropic — powers the sales advisor and the LLM-as-a-judge
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-opus-4-8

# Gemini — powers embeddings (Anthropic has no embeddings API)
GEMINI_API_KEY=...
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536

# xAI Grok — optional cross-family judge (controls for self-preference bias).
# JUDGE_PROVIDER: "anthropic" (default) or "grok"; `judge-agreement` runs both.
XAI_API_KEY=...
JUDGE_PROVIDER=anthropic
GROK_MODEL=grok-4

# Embedding backend: "gemini" (real) or "hash" (deterministic offline vectors
# for development and CI — no API key needed, retrieval still exercisable)
EMBED_BACKEND=gemini
